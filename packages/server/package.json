{
  "name": "@holodle/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @holodle/shared build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretypecheck": "pnpm --filter @holodle/shared build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @holodle/shared build",
    "test": "vitest run"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.0.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.2",
    "@holodle/shared": "workspace:*",
    "@napi-rs/canvas": "^1.0.0",
    "better-sqlite3": "^11.3.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
