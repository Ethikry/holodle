# Copy to .env and fill in values. .env is gitignored.

# --- Discord application ---
# From https://discord.com/developers/applications -> your app
# OAuth2 -> Client information
DISCORD_CLIENT_ID=
# OAuth2 -> Client information -> Reset Secret (server-only — never exposed to client)
DISCORD_CLIENT_SECRET=
# Bot tab -> Reset Token. Used to post the exit and EOD recap embeds via the
# Discord REST API. Server-only. The bot user must be invited to the test
# guild with the Send Messages permission for embeds to land.
DISCORD_BOT_TOKEN=

# --- Server ---
# Port the Fastify server listens on. The Vite dev server proxies /api here.
PORT=3001
# Path to the SQLite database file. In Docker/Fly this is /data/holodle.db.
DB_PATH=./holodle.db
# Comma-separated origins allowed by CORS in dev. Discord proxies the activity
# through https://<client_id>.discordsays.com so production needs no CORS.
CORS_ORIGINS=http://localhost:5173

# --- Client (Vite) ---
# Exposed to the browser bundle. The client_id is public; the secret is NOT.
VITE_DISCORD_CLIENT_ID=
